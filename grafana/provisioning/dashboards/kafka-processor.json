{
  "__inputs": [],
  "__requires": [],
  "annotations": { "list": [] },
  "description": "Kafka Processor — pipeline throughput, latency, dead letters, and JVM/system resources",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 104,
      "title": "Message Totals",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 1 },
      "id": 11,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "expr": "sum(kafka_processor_messages_received_total) or vector(0)", "legendFormat": "Received", "refId": "A" }
      ],
      "title": "Received",
      "type": "stat"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 1 },
      "id": 12,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "expr": "sum(kafka_processor_messages_published_total) or vector(0)", "legendFormat": "Published", "refId": "A" }
      ],
      "title": "Published",
      "type": "stat"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "orange" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "orange", "value": null }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 10, "y": 1 },
      "id": 13,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "expr": "sum(kafka_processor_messages_siphoned_total) or vector(0)", "legendFormat": "Siphoned", "refId": "A" }
      ],
      "title": "Siphoned",
      "type": "stat"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "red", "value": 1 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 14, "y": 1 },
      "id": 14,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "none" },
      "targets": [
        { "expr": "sum(kafka_processor_messages_failed_total) or vector(0)", "legendFormat": "Failed", "refId": "A" }
      ],
      "title": "Failed (Dead Letter)",
      "type": "stat"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 100 },
            { "color": "red", "value": 500 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 15,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background", "graphMode": "area" },
      "targets": [
        { "expr": "kafka_processor_messages_in_flight or vector(0)", "legendFormat": "In-Flight", "refId": "A" }
      ],
      "title": "In-Flight (live)",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 100,
      "title": "Pipeline Throughput",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "failed" },  "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "siphoned" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 1,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(kafka_processor_messages_received_total[1m])",  "legendFormat": "received",  "refId": "A" },
        { "expr": "rate(kafka_processor_messages_published_total[1m])", "legendFormat": "published", "refId": "B" },
        { "expr": "rate(kafka_processor_messages_siphoned_total[1m])",  "legendFormat": "siphoned",  "refId": "C" },
        { "expr": "rate(kafka_processor_messages_failed_total[1m])",    "legendFormat": "failed",    "refId": "D" }
      ],
      "title": "Message Rate (msg/s)",
      "type": "timeseries"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "kafka_processor_messages_in_flight or vector(0)",
          "legendFormat": "in-flight",
          "refId": "A"
        }
      ],
      "title": "In-Flight Messages",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 101,
      "title": "Latency",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(kafka_processor_e2e_latency_seconds_bucket[1m]))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(kafka_processor_e2e_latency_seconds_bucket[1m]))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(kafka_processor_e2e_latency_seconds_bucket[1m]))", "legendFormat": "P99", "refId": "C" }
      ],
      "title": "E2E Latency (includes processor delay)",
      "type": "timeseries"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 4,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(kafka_processor_pipeline_latency_seconds_bucket[1m]))", "legendFormat": "P50", "refId": "A" },
        { "expr": "histogram_quantile(0.95, rate(kafka_processor_pipeline_latency_seconds_bucket[1m]))", "legendFormat": "P95", "refId": "B" },
        { "expr": "histogram_quantile(0.99, rate(kafka_processor_pipeline_latency_seconds_bucket[1m]))", "legendFormat": "P99", "refId": "C" }
      ],
      "title": "Pipeline Latency (worker execution only)",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 102,
      "title": "Dead Letters",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 5,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "rate(kafka_processor_messages_failed_total[1m])", "legendFormat": "{{reason}}", "refId": "A" }
      ],
      "title": "Dead Letter Rate by Reason Code",
      "type": "timeseries"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 103,
      "title": "CPU & Memory",
      "type": "row"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0, "max": 1,
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 33 },
      "id": 6,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "process_cpu_usage",  "legendFormat": "JVM process CPU", "refId": "A" },
        { "expr": "system_cpu_usage",   "legendFormat": "System CPU",      "refId": "B" }
      ],
      "title": "CPU Usage",
      "type": "timeseries"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "id": 7,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",    "legendFormat": "heap used",     "refId": "A" },
        { "expr": "sum(jvm_memory_max_bytes{area=\"heap\"})",     "legendFormat": "heap max",      "refId": "B" },
        { "expr": "sum(jvm_memory_used_bytes{area=\"nonheap\"})", "legendFormat": "non-heap used", "refId": "C" }
      ],
      "title": "JVM Memory",
      "type": "timeseries"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "min": 0, "max": 1, "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 0.7 },
            { "color": "red", "value": 0.9 }
          ]}
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 41 },
      "id": 8,
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        { "expr": "sum(jvm_memory_used_bytes{area=\"heap\"}) / sum(jvm_memory_max_bytes{area=\"heap\"})", "legendFormat": "Heap %", "refId": "A" }
      ],
      "title": "Heap Utilization",
      "type": "stat"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "short", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 41 },
      "id": 9,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "jvm_threads_live_threads",   "legendFormat": "live",   "refId": "A" },
        { "expr": "jvm_threads_daemon_threads", "legendFormat": "daemon", "refId": "B" },
        { "expr": "jvm_threads_peak_threads",   "legendFormat": "peak",   "refId": "C" }
      ],
      "title": "JVM Threads",
      "type": "timeseries"
    },

    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }
      },
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 41 },
      "id": 10,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(jvm_gc_pause_seconds_bucket[1m]))", "legendFormat": "GC pause P95", "refId": "A" },
        { "expr": "rate(jvm_gc_pause_seconds_sum[1m]) / rate(jvm_gc_pause_seconds_count[1m])", "legendFormat": "GC pause avg", "refId": "B" }
      ],
      "title": "GC Pause Latency",
      "type": "timeseries"
    }

  ],

  "refresh": "5s",
  "schemaVersion": 38,
  "tags": ["kafka", "kafka-processor"],
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Kafka Processor",
  "uid": "kafka-processor-v1",
  "version": 1
}
