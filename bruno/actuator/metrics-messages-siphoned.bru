meta {
  name: Metrics - Messages Siphoned
  type: http
  seq: 8
}

get {
  url: {{baseUrl}}/actuator/metrics/kafka.processor.messages.siphoned
  body: none
  auth: none
}

params:query {
  ~tag: eventType:END
}

docs {
  Counter — incremented when a message is fast-pathed via a SiphonEvaluator match
  (e.g., BDE: eventType=END + backdated=true routed to siphon-bde-topic).

  Optional tag filter: tag=eventType:<value>
  Event types: NC, END, TRM, RNW
}
